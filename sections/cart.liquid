<section class="naju-cart" data-cart-page>
  <div class="container">
    <div class="naju-cart__head">
      <h1 class="naju-cart__title">Seu Carrinho</h1>
      {% if cart.item_count > 0 %}
        <p class="naju-cart__count" data-cart-count>
          {{ cart.item_count }}
          {% if cart.item_count == 1 %}item{% else %}itens{% endif %}
        </p>
      {% endif %}
    </div>

    {% if cart.item_count == 0 %}
      <!-- CARRINHO VAZIO -->
      <div class="naju-empty-state">
        <svg
          class="naju-empty-state__icon"
          width="64"
          height="64"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <circle cx="9" cy="21" r="1"/>
          <circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        <h2 class="naju-empty-state__title">Carrinho vazio</h2>
        <p class="naju-empty-state__desc">Você ainda não adicionou produtos ao carrinho.</p>
        <a href="/collections/all" class="naju-btn-primary" style="margin-top: 20px;">Ver produtos</a>
      </div>

    {% else %}
      <!-- CARRINHO COM ITENS -->
      <div class="naju-cart__grid">
        <!-- LISTA DE PRODUTOS -->
        <div class="naju-cart__items">
          <form action="{{ routes.cart_url }}" method="post" id="cart-form">
            {% for item in cart.items %}
              <div class="naju-cart-item" data-cart-item data-line="{{ forloop.index }}">
                <a href="{{ item.url }}" class="naju-cart-item__image">
                  {% if item.image %}
                    <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}">
                  {% else %}
                    <div class="naju-card__placeholder">
                      <svg
                        width="32"
                        height="32"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                      >
                        <rect x="3" y="3" width="18" height="18" rx="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <path d="m21 15-5-5L5 21"/>
                      </svg>
                    </div>
                  {% endif %}
                </a>

                <div class="naju-cart-item__info">
                  <a href="{{ item.url }}" class="naju-cart-item__title">{{ item.product.title }}</a>

                  {% if item.variant.title != 'Default Title' %}
                    <div class="naju-cart-item__variant">{{ item.variant.title }}</div>
                  {% endif %}

                  <div class="naju-cart-item__price">
                    <span data-line-price>{{ item.final_line_price | money }}</span>
                    {% if item.original_line_price > item.final_line_price %}
                      <span class="naju-cart-item__compare">{{ item.original_line_price | money }}</span>
                    {% endif %}
                  </div>
                </div>

                <div class="naju-cart-item__qty">
                  <div class="naju-qty" data-cart-qty>
                    <button type="button" class="naju-qty__btn" data-qty-minus aria-label="Diminuir">−</button>

                    <input
                      type="text"
                      inputmode="numeric"
                      pattern="[0-9]*"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      class="naju-qty__input"
                      data-line="{{ forloop.index }}"
                      aria-label="Quantidade"
                    >

                    <button type="button" class="naju-qty__btn" data-qty-plus aria-label="Aumentar">+</button>
                  </div>
                </div>

                <button type="button" class="naju-cart-item__remove" data-remove-line aria-label="Remover item">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                  </svg>
                </button>
              </div>
            {% endfor %}

            <button type="submit" name="update" class="naju-btn-update" style="display:none;">
              Atualizar carrinho
            </button>
          </form>
        </div>

        <!-- RESUMO DO PEDIDO -->
        <div class="naju-cart__summary">
          <div class="naju-summary">
            <h3 class="naju-summary__title">Resumo do pedido</h3>

            <div class="naju-summary__line">
              <span>Subtotal</span>
              <span class="naju-summary__value" data-cart-subtotal>{{ cart.total_price | money }}</span>
            </div>

            {% if cart.total_discount > 0 %}
              <div class="naju-summary__line naju-summary__line--discount">
                <span>Desconto</span>
                <span class="naju-summary__value">-{{ cart.total_discount | money }}</span>
              </div>
            {% endif %}

            <div class="naju-summary__note">Frete e impostos calculados no checkout</div>

            <div class="naju-summary__total">
              <span>Total</span>
              <span class="naju-summary__total-value" data-cart-total>{{ cart.total_price | money }}</span>
            </div>

            <button
              type="submit"
              name="checkout"
              value="checkout"
              class="naju-btn-checkout"
              form="cart-form"
            >
              Finalizar compra
            </button>

            <a href="/collections/all" class="naju-link-continue">← Continuar comprando</a>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</section>

<script>
  (function () {
    const cartPage = document.querySelector('[data-cart-page]');
    const form = document.getElementById('cart-form');

    if (!cartPage || !form) return;

    function formatMoney(cents, currency) {
      const value = Number(cents || 0) / 100;

      return new Intl.NumberFormat('pt-BR', {
        style: 'currency',
        currency: currency || 'BRL',
      }).format(value);
    }

    function setLoading(isLoading) {
      cartPage.classList.toggle('is-updating', isLoading);
    }

    function updateLineIndexes() {
      document.querySelectorAll('[data-cart-item]').forEach((item, index) => {
        const line = index + 1;
        item.setAttribute('data-line', line);

        const input = item.querySelector('.naju-qty__input');
        if (input) input.setAttribute('data-line', line);
      });
    }

    function updateCartUI(cart, changedLine, requestedQty) {
      const currency = cart.currency || 'BRL';

      const countEl = document.querySelector('[data-cart-count]');
      if (countEl) {
        countEl.textContent = cart.item_count + ' ' + (cart.item_count === 1 ? 'item' : 'itens');
      }

      const subtotalEl = document.querySelector('[data-cart-subtotal]');
      if (subtotalEl) subtotalEl.textContent = formatMoney(cart.total_price, currency);

      const totalEl = document.querySelector('[data-cart-total]');
      if (totalEl) totalEl.textContent = formatMoney(cart.total_price, currency);

      const itemEl = document.querySelector('[data-cart-item][data-line="' + changedLine + '"]');

      if (requestedQty === 0) {
        if (itemEl) itemEl.remove();

        if (cart.item_count === 0) {
          window.location.reload();
          return;
        }

        updateLineIndexes();
        return;
      }

      const updatedItem = cart.items[changedLine - 1];

      if (!itemEl || !updatedItem) {
        window.location.reload();
        return;
      }

      const input = itemEl.querySelector('.naju-qty__input');
      if (input) input.value = updatedItem.quantity;

      const linePriceEl = itemEl.querySelector('[data-line-price]');
      if (linePriceEl) {
        linePriceEl.textContent = formatMoney(updatedItem.final_line_price, currency);
      }
    }

    async function changeLine(line, quantity) {
      setLoading(true);

      try {
        const response = await fetch('/cart/change.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify({
            line: Number(line),
            quantity: Number(quantity),
          }),
        });

        if (!response.ok) {
          throw new Error('Erro ao atualizar carrinho');
        }

        const cart = await response.json();
        updateCartUI(cart, Number(line), Number(quantity));
      } catch (error) {
        console.error(error);
        alert('Não foi possível atualizar o carrinho. Tente novamente.');
        window.location.reload();
      } finally {
        setLoading(false);
      }
    }

    document.querySelectorAll('[data-cart-qty]').forEach((wrap) => {
      const input = wrap.querySelector('.naju-qty__input');
      const minus = wrap.querySelector('[data-qty-minus]');
      const plus = wrap.querySelector('[data-qty-plus]');
      const item = wrap.closest('[data-cart-item]');

      if (!input || !minus || !plus || !item) return;

      function getLine() {
        return item.getAttribute('data-line');
      }

      function cleanValue() {
        input.value = (input.value || '').replace(/[^\d]/g, '');
        if (input.value === '') input.value = '1';
      }

      minus.addEventListener('click', function () {
        cleanValue();

        const current = parseInt(input.value, 10) || 1;
        const next = Math.max(0, current - 1);

        input.value = String(next);
        changeLine(getLine(), next);
      });

      plus.addEventListener('click', function () {
        cleanValue();

        const current = parseInt(input.value, 10) || 1;
        const next = current + 1;

        input.value = String(next);
        changeLine(getLine(), next);
      });

      input.addEventListener('input', cleanValue);

      input.addEventListener('change', function () {
        cleanValue();
        changeLine(getLine(), parseInt(input.value, 10) || 1);
      });

      input.addEventListener('blur', function () {
        cleanValue();
      });
    });

    document.querySelectorAll('[data-remove-line]').forEach((button) => {
      button.addEventListener('click', function () {
        const item = button.closest('[data-cart-item]');
        if (!item) return;

        const line = item.getAttribute('data-line');
        changeLine(line, 0);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
